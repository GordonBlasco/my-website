---
export interface Props {
  title: string;
  authors: string;
  journal: string;
  paperUrl?: string;
  vizUrl?: string;
}

const { title, authors, journal, paperUrl, vizUrl } = Astro.props;
---

<article class="publication">
  <h3>
    {
      paperUrl ? (
        <a href={paperUrl} target="_blank" rel="noopener noreferrer">{title}</a>
      ) : (
        title
      )
    }
  </h3>
  <p class="authors">{authors}</p>
  <div class="publication-meta">
    <span>{journal}</span>
    <span class="links">
      {paperUrl && <a href={paperUrl} target="_blank" rel="noopener noreferrer">Paper</a>}
      {vizUrl && <a href={vizUrl} target="_blank" rel="noopener noreferrer">Visualization</a>}
    </span>
  </div>
</article>
