---
export interface Props {
  images: { src: string; alt?: string }[];
}

const { images } = Astro.props;
---

<div class="lightbox-carousel">
  <div class="carousel-track">
    {
      images.map((image, index) => (
        <button
          class="lightbox-trigger"
          type="button"
          data-src={image.src}
          data-alt={image.alt || `Image ${index + 1}`}
          aria-label={`Enlarge ${image.alt || `image ${index + 1}`}`}
        >
          <img src={image.src} alt={image.alt || `Image ${index + 1}`} loading="lazy" />
        </button>
      ))
    }
  </div>

  <dialog class="lightbox-dialog" aria-label="Image preview">
    <button class="lightbox-close" type="button" aria-label="Close image preview">×</button>
    <img src="" alt="" />
  </dialog>
</div>

<script>
  document.querySelectorAll<HTMLElement>(".lightbox-carousel").forEach((carousel) => {
    const dialog = carousel.querySelector<HTMLDialogElement>(".lightbox-dialog");
    const preview = dialog?.querySelector<HTMLImageElement>("img");
    const close = dialog?.querySelector<HTMLButtonElement>(".lightbox-close");

    carousel.querySelectorAll<HTMLButtonElement>(".lightbox-trigger").forEach((trigger) => {
      trigger.addEventListener("click", () => {
        if (!dialog || !preview) return;
        preview.src = trigger.dataset.src ?? "";
        preview.alt = trigger.dataset.alt ?? "";
        dialog.showModal();
      });
    });

    close?.addEventListener("click", () => dialog?.close());
    dialog?.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });
  });
</script>

<style>
  .lightbox-carousel {
    margin: 2rem 0;
  }

  .carousel-track {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.35rem;
  }

  .lightbox-trigger {
    min-width: 0;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: zoom-in;
  }

  .lightbox-trigger img {
    width: 100%;
    height: clamp(110px, 18vw, 165px);
    object-fit: cover;
  }

  .lightbox-trigger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .lightbox-dialog {
    width: fit-content;
    max-width: 90vw;
    max-height: 90vh;
    padding: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
  }

  .lightbox-dialog::backdrop {
    background: rgb(0 0 0 / 75%);
  }

  .lightbox-dialog img {
    width: auto;
    height: auto;
    max-width: calc(90vw - 1rem);
    max-height: calc(90vh - 1rem);
    object-fit: contain;
  }

  .lightbox-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 1.8rem;
    height: 1.8rem;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 50%;
    color: inherit;
    background: var(--surface);
    font: inherit;
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
  }

  .lightbox-close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  @media (max-width: 520px) {
    .carousel-track {
      grid-template-columns: repeat(2, 1fr);
    }

    .lightbox-trigger img {
      height: 120px;
    }
  }
</style>
