---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface Props {
  images: { src: ImageMetadata; alt?: string }[];
}

const { images } = Astro.props;

const optimizedImages = await Promise.all(
  images.map(async (image) => {
    const thumbnailWidth = Math.min(480, image.src.width);
    const lightboxWidth = Math.min(1200, image.src.width);

    const [thumbnail, lightbox] = await Promise.all([
      getImage({ src: image.src, width: thumbnailWidth, format: "webp", quality: 75 }),
      getImage({ src: image.src, width: lightboxWidth, format: "webp", quality: 85 }),
    ]);

    return { ...image, thumbnail, lightbox };
  }),
);
---

<div class="lightbox-carousel">
  <div class="carousel-track">
    {
      optimizedImages.map((image, index) => (
        <button
          class="lightbox-trigger"
          type="button"
          data-src={image.lightbox.src}
          data-alt={image.alt || `Image ${index + 1}`}
          aria-label={`Enlarge ${image.alt || `image ${index + 1}`}`}
        >
          <img
            src={image.thumbnail.src}
            width={image.thumbnail.attributes.width}
            height={image.thumbnail.attributes.height}
            alt={image.alt || `Image ${index + 1}`}
            loading="lazy"
            decoding="async"
          />
        </button>
      ))
    }
  </div>

  <dialog class="lightbox-dialog" aria-label="Image preview">
    <button class="lightbox-close" type="button" aria-label="Close image preview">×</button>
    <button class="lightbox-nav lightbox-previous" type="button" aria-label="Previous image">‹</button>
    <img src="" alt="" title="Click for next image" />
    <button class="lightbox-nav lightbox-next" type="button" aria-label="Next image">›</button>
  </dialog>
</div>

<script>
  document.querySelectorAll<HTMLElement>(".lightbox-carousel").forEach((carousel) => {
    const dialog = carousel.querySelector<HTMLDialogElement>(".lightbox-dialog");
    const preview = dialog?.querySelector<HTMLImageElement>("img");
    const close = dialog?.querySelector<HTMLButtonElement>(".lightbox-close");
    const previous = dialog?.querySelector<HTMLButtonElement>(".lightbox-previous");
    const next = dialog?.querySelector<HTMLButtonElement>(".lightbox-next");
    const triggers = Array.from(
      carousel.querySelectorAll<HTMLButtonElement>(".lightbox-trigger"),
    );
    let currentIndex = 0;

    const showImage = (index: number) => {
      if (!preview || triggers.length === 0) return;

      currentIndex = (index + triggers.length) % triggers.length;
      const trigger = triggers[currentIndex];
      preview.src = trigger.dataset.src ?? "";
      preview.alt = trigger.dataset.alt ?? "";
    };

    triggers.forEach((trigger, index) => {
      trigger.addEventListener("click", () => {
        if (!dialog || !preview) return;
        showImage(index);
        dialog.showModal();
      });
    });

    const showPrevious = () => showImage(currentIndex - 1);
    const showNext = () => showImage(currentIndex + 1);

    previous?.addEventListener("click", showPrevious);
    next?.addEventListener("click", showNext);
    preview?.addEventListener("click", showNext);
    close?.addEventListener("click", () => dialog?.close());
    dialog?.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        showPrevious();
      } else if (event.key === "ArrowRight") {
        event.preventDefault();
        showNext();
      }
    });
    dialog?.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });
  });
</script>

<style>
  .lightbox-carousel {
    margin: 2rem 0;
  }

  .carousel-track {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.35rem;
  }

  .lightbox-trigger {
    min-width: 0;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: zoom-in;
  }

  .lightbox-trigger img {
    width: 100%;
    height: clamp(110px, 18vw, 165px);
    object-fit: cover;
  }

  .lightbox-trigger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .lightbox-dialog {
    width: fit-content;
    max-width: 90vw;
    max-height: 90vh;
    padding: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
  }

  .lightbox-dialog::backdrop {
    background: rgb(0 0 0 / 75%);
  }

  .lightbox-dialog img {
    width: auto;
    height: auto;
    max-width: calc(90vw - 1rem);
    max-height: calc(90vh - 1rem);
    object-fit: contain;
    cursor: e-resize;
  }

  .lightbox-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 1.8rem;
    height: 1.8rem;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 50%;
    color: inherit;
    background: var(--surface);
    font: inherit;
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
  }

  .lightbox-close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    width: 2.5rem;
    height: 3.5rem;
    padding: 0;
    transform: translateY(-50%);
    border: 0;
    color: inherit;
    background: transparent;
    font: inherit;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
  }

  .lightbox-previous {
    left: 0.75rem;
  }

  .lightbox-next {
    right: 0.75rem;
  }

  .lightbox-nav:focus-visible {
    outline: none;
  }

  @media (max-width: 520px) {
    .carousel-track {
      grid-template-columns: repeat(2, 1fr);
    }

    .lightbox-trigger img {
      height: 120px;
    }
  }
</style>
