---
import { Image } from "astro:assets";

const { src, alt = "", caption = "" } = Astro.props;
---

<figure class="polaroid">
  {
    typeof src === "string" ? (
      <img src={src} alt={alt} loading="lazy" decoding="async" />
    ) : (
      <Image
        src={src}
        alt={alt}
        width={500}
        widths={[250, 500]}
        sizes="(max-width: 520px) 210px, 250px"
        format="webp"
        loading="eager"
      />
    )
  }
  {caption && <div class="caption">{caption}</div>}
</figure>

<style>
  .polaroid {
  background: #fffbef;
  color: #222;
  padding: 10px 10px 30px 10px;
  border: 3px solid black;
  border-radius: 4px;
  box-shadow:
    2px 2px 0 var(--polaroid-shadow-near),
    4px 4px 0 var(--polaroid-shadow-mid),
    8px 8px 0 var(--polaroid-shadow-far);
  display: inline-block;
  text-align: center;
  max-width: 250px;
  margin: 1rem;
  font-family: var(--font-body);
  transition: transform 0.1s ease;
  transform: rotate(-1deg); /* subtle imperfection */
}

.polaroid:hover {
  transform: rotate(1deg) scale(1.02);
}

.polaroid img {
  width: 100%;
  height: auto;
  display: block;
  border: 2px solid black;
  filter: contrast(1.1) saturate(1.2);
}

.caption {
  margin-top: 10px;
  font-size: 0.9rem;
  color: #222;
  font-style: italic;
}

</style>
